# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/meatApp?retryWrites=true&w=majority

# JWT Secret for Admin Authentication
JWT_SECRET=your_super_secret_jwt_key_here

# WhatsApp Notifications via Twilio (Optional but Recommended)
# Sign up at: https://www.twilio.com/
# Get credentials from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
ADMIN_WHATSAPP_NUMBER=whatsapp:+919876543210

# Alternative: HTTP-based WhatsApp API (e.g., WATI, Interakt, WhatsApp Business API)
# Uncomment and configure if using a different service
# WHATSAPP_API_URL=https://api.yourprovider.com/send
# WHATSAPP_API_KEY=your_api_key_here
# ADMIN_PHONE_NUMBER=919876543210

# Server Configuration
PORT=5000
